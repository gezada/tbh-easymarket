{
  "name": "tbh-easy-market",
  "version": "1.0.0",
  "description": "TBH Easy Market: valor do baú e preços do Mercado Steam do TBH: Task Bar Hero. 100% read-only.",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "extract-tables": "node scripts/extract-tbh-tables.mjs",
    "dist": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.eusouogiba.tbheasymarket",
    "productName": "TBH Easy Market",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "icon/tbh-easymarket-icon.png"
    },
    "portable": {
      "artifactName": "${productName} ${version} (Portable).exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "gezada",
      "repo": "tbh-easymarket"
    }
  },
  "keywords": [
    "steam",
    "market",
    "taskbar-hero",
    "tbh",
    "inventory",
    "price",
    "eusouogiba"
  ],
  "author": "EuSouOGiba (https://eusouogiba.com)",
  "license": "MIT",
  "homepage": "https://github.com/lezards/giba-steam-market",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
